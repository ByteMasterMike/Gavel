# PostgreSQL (required). Nhost: Database → copy Postgres URI; append ?sslmode=require if the host expects TLS.
# Example: postgresql://postgres:password@db.xxx.nhost.run:5432/postgres?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# NextAuth — generate: openssl rand -base64 32
AUTH_SECRET=""
AUTH_TRUST_HOST="true"

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Anthropic — ruling evaluation (optional: scoring falls back if unset)
ANTHROPIC_API_KEY=""
