# PostgreSQL (required). Nhost: Database → copy Postgres URI; append ?sslmode=require if the host expects TLS.
# Example: postgresql://postgres:password@db.xxx.nhost.run:5432/postgres?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# NextAuth — required on Vercel: generate with openssl rand -base64 32 (non-empty)
# NEXTAUTH_SECRET is accepted as an alias if you use older docs/tutorials.
AUTH_SECRET=""
AUTH_TRUST_HOST="true"

# Production (Vercel): set to your canonical origin so OAuth callbacks match Google Cloud Console.
# Example: https://your-app.vercel.app  (NEXTAUTH_URL is synced into AUTH_URL if AUTH_URL is unset)
AUTH_URL=""
NEXTAUTH_URL=""

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Google Gemini — ruling evaluation (optional: scoring falls back if unset)
# API key: https://aistudio.google.com/apikey  (alias: GOOGLE_AI_API_KEY)
GEMINI_API_KEY=""
# Optional: model id (default gemini-2.0-flash)
# GEMINI_MODEL="gemini-2.0-flash"
# Optional: USD per 1M tokens for monthly budget estimates (defaults match typical Flash pricing)
# GEMINI_INPUT_USD_PER_MTOK="0.10"
# GEMINI_OUTPUT_USD_PER_MTOK="0.40"
# Optional: transient API retries (429 / overload / network). Extra retries after the first attempt; default 2 => 3 total tries.
# GEMINI_MAX_RETRIES="2"
# GEMINI_RETRY_BASE_MS="800"
# Optional: max output tokens for reasoning JSON (default 1536; truncation retry bumps to at least 2048)
# GEMINI_REASONING_MAX_OUTPUT_TOKENS="1536"

# Stitch MCP (Cursor IDE only): copy .cursor/mcp.json.example → .cursor/mcp.json, set X-Goog-Api-Key, restart Cursor. Not read by Next.js.

# --- Production checklist (run against the same DATABASE_URL as Vercel) ---
# 1) DATABASE_URL must include sslmode=require for Nhost/managed Postgres when required.
# 2) npx dotenv -e .env -- prisma migrate deploy
# 3) npx dotenv -e .env -- prisma db seed
# 4) Set AUTH_URL on Vercel to https://<your-deployment>.vercel.app and redeploy.
# 5) If the docket never loads, open /api/health and check Vercel function logs.
