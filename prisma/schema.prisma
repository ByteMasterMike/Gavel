generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CaseKind {
  CRIMINAL
  CIVIL
}

enum RulingStatus {
  PENDING
  SCORED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  rulings       UserRuling[]

  careerPoints Int       @default(0)
  currentTier  Int       @default(1)
  streakDays   Int       @default(0)
  lastPlayedAt DateTime?
  timezone     String    @default("America/New_York")

  lastMorningDocketLocalDate String?
  tierAccuracyWarning        Boolean @default(false)
  rulingsSinceTierWarning    Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Case {
  id                       String   @id @default(cuid())
  title                    String
  tier                     Int
  kind                     CaseKind
  category                 String
  briefSummary             String   @db.Text
  parTimeMinutes           Int
  correctVerdict           String
  correctSentenceText      String   @db.Text
  correctSentenceNumeric   Float?
  correctReasoningSummary  String   @db.Text
  actualOpinionExcerpt     String   @db.Text
  isOverturned             Boolean  @default(false)
  appellateReversalSummary String?  @db.Text
  // Appellate outcome anchors for Prescient Justice (§10) when isOverturned.
  appellateCorrectVerdict         String?
  appellateCorrectSentenceNumeric Float?
  whyExplanation           String   @db.Text
  maxPrecedents            Int      @default(5)

  documents       CaseDocument[]
  precedents      Precedent[]
  rulings         UserRuling[]
  dailyChallenges DailyChallenge[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CaseDocument {
  id           String  @id @default(cuid())
  caseId       String
  title        String
  content      String  @db.Text
  sortOrder    Int     @default(0)
  isAdmissible Boolean @default(true)
  isMaterial   Boolean @default(false)

  case Case @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
}

model Precedent {
  id               String  @id @default(cuid())
  caseId           String
  name             String
  citation         String
  summary          String  @db.Text
  sortOrder        Int     @default(0)
  isRelevant       Boolean @default(false)
  weightMultiplier Float   @default(1.0)

  case Case @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
}

model UserRuling {
  id     String @id @default(cuid())
  userId String
  caseId String

  verdict           String
  sentenceText      String   @db.Text
  sentenceNumeric   Float?
  findingsOfFact    String   @db.Text
  applicationOfLaw  String   @db.Text
  mitigatingFactors String   @db.Text

  flaggedDocIds     String[] @default([])
  starredDocIds     String[] @default([])
  citedPrecedentIds String[] @default([])
  openedDocIds      String[] @default([])
  hintsUsed         Int      @default(0)
  verdictFlips      Int      @default(0)

  startedAt   DateTime
  submittedAt DateTime

  accuracyScore        Int?
  styleScore           Int?
  totalScore           Int?
  llmScoreRaw          Float?
  llmFeedback          String? @db.Text
  scoreBreakdown       Json?
  judgeRank            String?
  judgeRankDescription String? @db.Text

  status RulingStatus @default(PENDING)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  case Case @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([caseId])
}

model DailyChallenge {
  id     String   @id @default(cuid())
  date   DateTime @unique @db.Date
  caseId String

  case Case @relation(fields: [caseId], references: [id], onDelete: Cascade)
}
